---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import { getCollection } from "astro:content";
import { SITE, url } from "../lib/site";

const categories = (await getCollection("categories")).sort(
  (a, b) => a.data.order - b.data.order
);

const articles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 6);
---

<BaseLayout
  title={`${SITE.nameJa} - 日用品・消耗品のコスパ比較サイト`}
  description={SITE.description}
>
  <!-- ヒーロー -->
  <section class="bg-gradient-to-br from-sky-50 to-emerald-50 border-b border-[var(--color-border)]">
    <Container class="py-16 md:py-24 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-[var(--color-text)] mb-4 leading-tight">
        毎日の日用品を<br class="md:hidden" /><span class="text-[var(--color-primary)]">かしこく</span>選ぼう
      </h1>
      <p class="text-[var(--color-text-sub)] text-lg md:text-xl mb-8 max-w-xl mx-auto leading-relaxed">
        トイレットペーパーから洗濯洗剤まで、<br class="hidden md:inline" />
        コスパを徹底比較してお得な買い物をサポートします。
      </p>
      <a
        href="#categories"
        class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity shadow-sm hover:shadow-md min-h-[52px] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
      >
        人気カテゴリを見る
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </Container>
  </section>

  <!-- カテゴリグリッド -->
  <section id="categories" class="py-12 md:py-20">
    <Container>
      <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">人気カテゴリ</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map((cat) => (
          <a
            href={url(`/category/${cat.data.slug}`)}
            class="group bg-white rounded-xl p-5 border border-[var(--color-border)] shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all text-center focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
          >
            <div class="text-3xl mb-3" aria-hidden="true">{cat.data.icon}</div>
            <h3 class="font-semibold text-[var(--color-text)] text-sm group-hover:text-[var(--color-primary)] transition-colors leading-snug">
              {cat.data.name}
            </h3>
            <p class="text-xs text-[var(--color-text-sub)] mt-1.5 line-clamp-2 leading-relaxed">
              {cat.data.description.slice(0, 40)}…
            </p>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- 最新記事 -->
  {articles.length > 0 && (
    <section id="articles" class="py-12 md:py-20 bg-[var(--color-surface)]">
      <Container>
        <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">最新の比較記事</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {articles.map((article) => (
            <a
              href={url(`/articles/${article.id}`)}
              class="group bg-white rounded-xl border border-[var(--color-border)] shadow-sm hover:shadow-md transition-all overflow-hidden focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
            >
              <div class="p-5">
                <p class="text-xs text-[var(--color-primary)] font-medium mb-2">
                  {article.data.category.id}
                </p>
                <h3 class="font-bold text-[var(--color-text)] leading-snug group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">
                  {article.data.title}
                </h3>
                <p class="text-sm text-[var(--color-text-sub)] mt-2 line-clamp-2 leading-relaxed">
                  {article.data.description}
                </p>
                <time
                  datetime={article.data.publishedAt.toISOString()}
                  class="block text-xs text-[var(--color-text-sub)] mt-3"
                >
                  {article.data.publishedAt.toLocaleDateString("ja-JP")}
                </time>
              </div>
            </a>
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- アフィリエイト表記 -->
  <section class="py-8">
    <Container>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800 text-center">
        当サイトのリンクには楽天アフィリエイトプログラムに参加しています。商品購入により当サイトが報酬を得る場合があります。
      </div>
    </Container>
  </section>
</BaseLayout>
