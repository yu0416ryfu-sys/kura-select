---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import ComparisonTable from "../components/product/ComparisonTable.astro";
import ProductCard from "../components/product/ProductCard.astro";
import TopPickCta from "../components/product/TopPickCta.astro";
import AffiliateLink from "../components/product/AffiliateLink.astro";
import {
  getLowestOffer,
  getRakutenFallbackOffer,
  getOfferPriceSummary,
  getVisibleOffers,
  getEnabledAffiliateProvidersFromEnv,
  getStaticAffiliateProvidersFromEnv,
  sortOffersByPriceForDisplay,
  getLowestVisibleOffer,
  getRakutenRating,
} from "../lib/offers";
import { formatPriceOrConfirmation, isKnownPrice, shouldShowPricePerUnit } from "../lib/price";
import { calcPricePerUnit, getArticleTargetUnit } from "../lib/capacity";
import { SITE, url } from "../lib/site";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import ArticleToc from "../components/article/ArticleToc.astro";
import SaleBanner from "../components/article/SaleBanner.astro";
import FaqList from "../components/article/FaqList.astro";

const linkProviders = getEnabledAffiliateProvidersFromEnv(import.meta.env);
const priceProviders = getStaticAffiliateProvidersFromEnv(import.meta.env);
const jsonLdProviders = getStaticAffiliateProvidersFromEnv(import.meta.env);

interface Props {
  article: CollectionEntry<"articles">;
  categoryName: string;
  categorySlug: string;
  relatedArticles: CollectionEntry<"articles">[];
  headings?: MarkdownHeading[];
}

const { article, categoryName, categorySlug, relatedArticles, headings } = Astro.props;
const { data } = article;
const isComparison = data.articleType !== "review";

type TocItem = { slug: string; text: string; depth: 2 | 3 };

const markdownTocItems: TocItem[] = (headings ?? [])
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth as 2 | 3 }));

const rawTocItems: TocItem[] = [
  ...(isComparison && data.products.length > 0
    ? [{ slug: "comparison-table", text: "商品比較表", depth: 2 as const }]
    : []),
  ...markdownTocItems,
  ...(data.faqs && data.faqs.length > 0
    ? [{ slug: "faq", text: "よくある質問", depth: 2 as const }]
    : []),
  ...(data.products.length > 0
    ? [{ slug: "product-details", text: isComparison ? "各商品の詳細" : "商品情報", depth: 2 as const }]
    : []),
];

const seenSlugs = new Set<string>();
const seenTexts = new Set<string>();
const tocItems = rawTocItems.filter((item) => {
  const textKey = `${item.depth}:${item.text}`;
  if (seenSlugs.has(item.slug) || seenTexts.has(textKey)) return false;
  seenSlugs.add(item.slug);
  seenTexts.add(textKey);
  return true;
});
const targetUnit = getArticleTargetUnit(article.id);

// 記事別OGP画像パス（ビルド時に generate-ogp.mjs で生成）
const ogImage = `/og/articles/${article.id}.png`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title,
  description: data.description,
  datePublished: data.publishedAt.toISOString(),
  dateModified: (data.updatedAt ?? data.publishedAt).toISOString(),
  author: {
    "@type": "Person",
    "@id": `${SITE.url}/about/#person`,
    name: "ゆきんこ",
    url: `${SITE.url}/about/`,
  },
  publisher: { "@type": "Organization", name: SITE.nameJa },
  image: data.heroImage ? String(data.heroImage) : `${SITE.url}${SITE.ogImage}`,
  url: `${SITE.url}/articles/${article.id}`,
};

// FAQPage 構造化データ用に answer をプレーンテキスト化する。
// 先頭の A. / **A.** ラベルと太字記法（**）を除去する（移行漏れデータの保険）。
const cleanFaqText = (text: string): string =>
  text
    .replace(/^\*{0,2}A[.．:：]\*{0,2}\s*/, "")
    .replace(/\*\*([^*]+)\*\*/g, "$1");

// FAQ がある記事のみ FAQPage 構造化データを出力する
const faqJsonLd = data.faqs && data.faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: data.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: cleanFaqText(faq.answer),
    },
  })),
} : null;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "ホーム", item: SITE.url },
    { "@type": "ListItem", position: 2, name: categoryName, item: `${SITE.url}/category/${categorySlug}` },
    { "@type": "ListItem", position: 3, name: data.title, item: `${SITE.url}/articles/${article.id}` },
  ],
};

// JSON-LD は楽天・Yahoo のみ（Amazon は 24h 鮮度を SSG で保証できないため除外）
const productJsonLds = data.products
  .filter((p) => p.rating !== undefined)
  .map((p) => {
    let jsonLdOffer: { price: number; url: string } | null = null;
    const lowest = getLowestOffer(p, { enabledProviders: jsonLdProviders });
    if (lowest) jsonLdOffer = { price: lowest.price, url: lowest.url };
    if (!jsonLdOffer) {
      const rakuten = getRakutenFallbackOffer(p);
      if (rakuten && typeof rakuten.price === "number" && rakuten.price > 0) {
        jsonLdOffer = { price: rakuten.price, url: rakuten.url };
      }
    }
    return { product: p, jsonLdOffer };
  })
  .filter(({ jsonLdOffer }) => jsonLdOffer !== null)
  .map(({ product: p, jsonLdOffer }) => ({
    "@context": "https://schema.org",
    "@type": "Product",
    name: p.name,
    description: `${p.brand}の${p.name}。${p.capacity}。${p.recommendedFor}`,
    brand: { "@type": "Brand", name: p.brand },
    image: p.imageUrl || `${SITE.url}${SITE.ogImage}`,
    offers: {
      "@type": "Offer",
      priceCurrency: "JPY",
      price: jsonLdOffer!.price,
      url: jsonLdOffer!.url,
      availability: "https://schema.org/InStock",
      shippingDetails: {
        "@type": "OfferShippingDetails",
        shippingDestination: {
          "@type": "DefinedRegion",
          addressCountry: "JP",
        },
      },
      hasMerchantReturnPolicy: {
        "@type": "MerchantReturnPolicy",
        applicableCountry: "JP",
        returnPolicyCategory: "https://schema.org/MerchantReturnNotPermitted",
      },
    },
    aggregateRating: (() => {
      const r = getRakutenRating(p);
      return r
        ? {
            "@type": "AggregateRating",
            ratingValue: r.rating,
            reviewCount: r.reviewCount,
            bestRating: 5,
            worstRating: 1,
          }
        : undefined;
    })(),
  }));
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogImage={ogImage}
  ogType="article"
>
  <Fragment slot="head">
    <JsonLd data={articleJsonLd} />
    <JsonLd data={breadcrumbJsonLd} />
    {faqJsonLd && <JsonLd data={faqJsonLd} />}
    {productJsonLds.map((ld) => <JsonLd data={ld} />)}
  </Fragment>

  <Container class="py-8 md:py-12">
    <!-- パンくずリスト -->
    <nav aria-label="パンくずリスト" class="mb-6">
      <ol class="flex items-center gap-1.5 text-sm text-[var(--color-text-sub)] flex-wrap">
        <li><a href={url("/")} class="hover:text-[var(--color-primary)] transition-colors">ホーム</a></li>
        <li aria-hidden="true" class="text-[var(--color-border)]">/</li>
        <li><a href={url(`/category/${categorySlug}`)} class="hover:text-[var(--color-primary)] transition-colors">{categoryName}</a></li>
        <li aria-hidden="true" class="text-[var(--color-border)]">/</li>
        <li class="text-[var(--color-text)] font-medium truncate max-w-xs">{data.title}</li>
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-10">
      <!-- メインコンテンツ -->
      <article>
        <!-- 記事ヘッダー -->
        <header class="mb-8">
          <div class="flex items-center gap-2 mb-3">
            <a
              href={url(`/category/${categorySlug}`)}
              class="inline-block bg-sky-100 text-sky-700 text-xs font-medium px-2.5 py-0.5 rounded-full hover:bg-sky-200 transition-colors"
            >
              {categoryName}
            </a>
          </div>
          <h1 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] leading-tight mb-4">
            {data.title}
          </h1>
          <div class="flex items-center gap-4 text-sm text-[var(--color-text-sub)]">
            {data.updatedAt ? (
              <>
                <time datetime={data.updatedAt.toISOString()}>
                  更新: {data.updatedAt.toLocaleDateString("ja-JP")}
                </time>
                <time datetime={data.publishedAt.toISOString()}>
                  公開: {data.publishedAt.toLocaleDateString("ja-JP")}
                </time>
              </>
            ) : (
              <time datetime={data.publishedAt.toISOString()}>
                公開: {data.publishedAt.toLocaleDateString("ja-JP")}
              </time>
            )}
          </div>
        </header>

        <!-- セール期間バナー（PUBLIC_SALE_ACTIVE=true のときのみ表示） -->
        <SaleBanner />

        <!-- ファーストビューCTA: comparison のみ（1位商品） -->
        {isComparison && data.products.length > 0 && (
          <TopPickCta product={data.products.find((p) => p.rank === 1) ?? data.products[0]} targetUnit={targetUnit} />
        )}

        <!-- 目次（モバイル: 比較表の前） -->
        <ArticleToc items={tocItems} class="mt-6 lg:hidden" />

        <!-- 比較表（comparison のみ） -->
        {isComparison && data.products.length > 0 && (
          <section id="comparison-table" aria-label="商品比較表" class="scroll-mt-24">
            <ComparisonTable products={data.products} caption={`${data.title} 比較表`} targetUnit={targetUnit} />
          </section>
        )}

        <!-- 記事本文 -->
        <div class="prose prose-slate max-w-none mt-8 [&_h2]:text-xl [&_h2]:font-bold [&_h2]:mt-8 [&_h2]:mb-4 [&_h2]:scroll-mt-24 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-6 [&_h3]:mb-3 [&_h3]:scroll-mt-24 [&_p]:mb-4 [&_ul]:mb-4 [&_li]:mb-1 [&_a]:text-[var(--color-primary)] [&_a]:font-medium [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-1 [&_a]:transition-colors [&_a:hover]:text-sky-700 [&_a:hover]:decoration-2 [&_table]:w-full [&_table]:text-sm [&_th]:bg-[var(--color-surface)] [&_th]:px-3 [&_th]:py-2 [&_td]:px-3 [&_td]:py-2 [&_td]:border-b [&_td]:border-[var(--color-border)]">
          <slot />
        </div>

        <!-- よくある質問（FAQ）: frontmatter faqs を唯一のソースとしてカード表示 -->
        {data.faqs && data.faqs.length > 0 && (
          <FaqList faqs={data.faqs} />
        )}

        <!-- 記事本文後インライン CTA（comparison: 1位商品 / review: 紹介商品） -->
        {data.products.length > 0 && (() => {
          const top = data.products.find((p) => p.rank === 1) ?? data.products[0];
          const yahooSearchFallback = {
            enabled: import.meta.env.PUBLIC_ENABLE_YAHOO_AFFILIATE === "true",
            sid: import.meta.env.VALUECOMMERCE_SID,
            pid: import.meta.env.VALUECOMMERCE_PID,
          };
          const amazonSearchFallback = {
            enabled: import.meta.env.PUBLIC_ENABLE_AMAZON_AFFILIATE === "true",
            tag: import.meta.env.AMAZON_ASSOCIATE_TAG,
          };
          const visibleOffers = getVisibleOffers(top, { enabledProviders: linkProviders, yahooSearchFallback, amazonSearchFallback });
          const sortedOffers = sortOffersByPriceForDisplay(visibleOffers);
          const lowestVisibleOffer = getLowestVisibleOffer(visibleOffers);
          const isLowestOffer = (offer: typeof visibleOffers[number]) =>
            lowestVisibleOffer
              ? offer.provider === lowestVisibleOffer.provider && offer.url === lowestVisibleOffer.url
              : offer.provider === "rakuten";
          const topSummary = getOfferPriceSummary(top, { enabledProviders: priceProviders });
          const topDisplayPrice = topSummary.lowestPrice ?? (isKnownPrice(top.price) ? top.price : null);
          // コスパ（単価）は最安サイトの価格 × capacity から表示時計算する
          const topLowestPricePerUnit = topDisplayPrice != null ? calcPricePerUnit(topDisplayPrice, top.capacity, targetUnit) : null;
          const topPricePerUnitText =
            shouldShowPricePerUnit(topDisplayPrice, topLowestPricePerUnit)
              ? `　${topLowestPricePerUnit}`
              : "";
          return (
            <div class="mt-8 p-4 md:p-5 bg-sky-50 border border-sky-200 rounded-xl flex flex-col sm:flex-row items-start sm:items-center gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-xs font-semibold text-sky-600 mb-1">{isComparison ? "この記事の結論" : "紹介商品"}</p>
                <p class="font-bold text-[var(--color-text)] text-sm leading-snug line-clamp-2">{top.name}</p>
                <p class="text-sm text-[var(--color-text-sub)] mt-0.5">{formatPriceOrConfirmation(topDisplayPrice)}{topPricePerUnitText}</p>
                {topSummary.priceDifferenceLabel && (
                  <p class="text-xs text-sky-600 mt-0.5">{topSummary.priceDifferenceLabel}</p>
                )}
              </div>
              <div class="flex flex-col sm:flex-row gap-2">
                {sortedOffers.map((offer) => (
                  <AffiliateLink
                    href={offer.url}
                    provider={offer.provider}
                    label={offer.label}
                    productName={top.name}
                    size="sm"
                    variant={isLowestOffer(offer) ? "primary" : "outline"}
                  />
                ))}
              </div>
            </div>
          );
        })()}

        <!-- 商品詳細セクション -->
        {data.products.length > 0 && (
          <section id="product-details" aria-label={isComparison ? "商品詳細" : "商品情報"} class="mt-10 scroll-mt-24">
            <h2 class="text-xl font-bold mb-6">{isComparison ? "各商品の詳細" : "商品情報"}</h2>
            <div class="space-y-6">
              {data.products.map((product) => (
                <ProductCard product={product} id={`product-${product.rank}`} targetUnit={targetUnit} />
              ))}
            </div>
          </section>
        )}

        <!-- アフィリエイト表記 -->
        <div class="mt-10 p-4 bg-amber-50 rounded-xl border border-amber-200 text-sm text-amber-800">
          <p class="font-semibold mb-1">広告・免責事項</p>
          <p>当サイトのリンクには楽天・Yahoo!ショッピング・Amazon等のアフィリエイトを含みます。商品購入により当サイトが報酬を得る場合があります。掲載価格は執筆時点のものです。最新価格は各ショップでご確認ください。</p>
        </div>
      </article>

      <!-- サイドバー -->
      <aside>
        <!-- 目次（デスクトップ: サイドバー上部） -->
        <ArticleToc items={tocItems} class="hidden lg:block lg:sticky lg:top-6" />

        <!-- 関連記事 -->
        {relatedArticles.length > 0 && (
          <div class="mt-8 bg-[var(--color-surface)] rounded-xl p-5 border border-[var(--color-border)]">
            <h2 class="font-bold text-[var(--color-text)] mb-4">関連記事</h2>
            <ul class="space-y-3">
              {relatedArticles.slice(0, 3).map((a) => (
                <li>
                  <a
                    href={url(`/articles/${a.id}`)}
                    class="block hover:text-[var(--color-primary)] transition-colors"
                  >
                    <span class="text-sm font-medium leading-snug">{a.data.title}</span>
                    <span class="block text-xs text-[var(--color-text-sub)] mt-0.5">
                      {a.data.publishedAt.toLocaleDateString("ja-JP")}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </Container>
</BaseLayout>
