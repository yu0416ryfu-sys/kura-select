---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import BaseSeo from "../components/seo/BaseSeo.astro";
import { url } from "../lib/site";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: string;
}

const { title, description, ogImage, canonical, noindex, ogType } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseSeo
      title={title}
      description={description}
      ogImage={ogImage}
      canonical={canonical}
      noindex={noindex}
      ogType={ogType}
    />
    <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")} />
    <slot name="head" />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-9ZPLHX62KS"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9ZPLHX62KS');
    </script>

    <!-- 楽天リンクのクリックをGA4に送信 -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        document.addEventListener('click', function(e) {
          // クリックされた要素、またはその親要素に data-ga-event があるか探す
          var link = e.target.closest('[data-ga-event]');
          if (!link) return;

          // GA4にイベントを送信
          if (typeof gtag === 'function') {
            gtag('event', link.dataset.gaEvent, {
              product_name: link.dataset.gaProduct || '不明',
              link_url: link.href || ''
            });
          }
        });
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-bg)]">
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
