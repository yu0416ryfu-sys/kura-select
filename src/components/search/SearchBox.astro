---
import { url } from "../../lib/site";

interface Props {
  value?: string;
  label?: string;
}

const { value = "", label = "商品名・カテゴリ・記事名で探す" } = Astro.props;
---

<form action={url("/search")} method="get" role="search" class="w-full max-w-2xl mx-auto">
  <label for="site-search" class="sr-only">{label}</label>
  <div class="flex flex-col sm:flex-row gap-3">
    <input
      id="site-search"
      name="q"
      type="search"
      value={value}
      placeholder={label}
      class="min-h-[52px] flex-1 rounded-xl border border-[var(--color-border)] bg-white px-4 text-base text-[var(--color-text)] shadow-sm outline-none transition-colors placeholder:text-[var(--color-text-sub)] focus:border-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
    />
    <button
      type="submit"
      class="inline-flex min-h-[52px] items-center justify-center rounded-xl bg-[var(--color-primary)] px-6 font-semibold text-white shadow-sm transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
    >
      検索
    </button>
  </div>
</form>
