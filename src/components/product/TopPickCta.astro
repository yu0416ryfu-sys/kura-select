---
import AffiliateLink from "./AffiliateLink.astro";
import {
  getVisibleOffers,
  getOfferPriceSummary,
  getEnabledAffiliateProvidersFromEnv,
  getStaticAffiliateProvidersFromEnv,
  type ProductOffer,
} from "../../lib/offers";

const linkProviders = getEnabledAffiliateProvidersFromEnv(import.meta.env);
const priceProviders = getStaticAffiliateProvidersFromEnv(import.meta.env);

interface Product {
  rank: number;
  name: string;
  brand: string;
  price: number;
  capacity: string;
  pricePerUnit?: string;
  rating?: number;
  reviewCount?: number;
  rakutenUrl: string;
  imageUrl?: string;
  offers?: ProductOffer[];
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const yahooSearchFallback = {
  enabled: import.meta.env.PUBLIC_ENABLE_YAHOO_AFFILIATE === "true",
  sid: import.meta.env.VALUECOMMERCE_SID,
  pid: import.meta.env.VALUECOMMERCE_PID,
};
const visibleOffers = getVisibleOffers(product, { enabledProviders: linkProviders, yahooSearchFallback });
const priceSummary = getOfferPriceSummary(product, { enabledProviders: priceProviders });
const displayPrice = priceSummary.lowestPrice ?? product.price;
---

<div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-4 md:p-5 mb-8 shadow-sm">
  <div class="flex items-center gap-2 mb-3">
    <span class="bg-amber-400 text-white text-xs font-bold px-2.5 py-1 rounded-full">🏆 編集部イチオシ</span>
    <span class="text-xs text-[var(--color-text-sub)]">この記事の1位</span>
  </div>

  <div class="flex items-center gap-4">
    <!-- 商品画像 -->
    <div class="shrink-0 w-16 h-16 md:w-20 md:h-20 rounded-lg overflow-hidden bg-white border border-[var(--color-border)]">
      <img
        src={product.imageUrl || "/placeholder/product-default.svg"}
        alt={`${product.name}の商品画像`}
        width="80"
        height="80"
        class="w-full h-full object-contain"
        loading="eager"
      />
    </div>

    <!-- 商品情報 -->
    <div class="flex-1 min-w-0">
      <p class="text-xs text-[var(--color-text-sub)]">{product.brand}</p>
      <h2 class="font-bold text-sm md:text-base text-[var(--color-text)] leading-tight line-clamp-2">
        {product.name}
      </h2>
      <div class="flex items-center gap-3 mt-1.5 flex-wrap">
        <span class="text-lg font-bold text-[var(--color-text)]">¥{displayPrice.toLocaleString()}</span>
        {priceSummary.priceRows.length >= 2 && priceSummary.priceDifferenceLabel && (
          <span class="text-xs text-sky-600">{priceSummary.priceDifferenceLabel}</span>
        )}
        {product.pricePerUnit && priceSummary.lowestProvider === "rakuten" && (
          <span class="bg-[var(--color-accent)] text-white text-xs px-2 py-0.5 rounded-full font-medium">
            {product.pricePerUnit}
          </span>
        )}
        {product.rating !== undefined && (
          <span class="flex items-center gap-0.5 text-sm">
            <span class="text-[var(--color-warning)]">★</span>
            <span class="font-medium">{product.rating.toFixed(1)}</span>
          </span>
        )}
      </div>
    </div>

    <!-- CTAボタン（PC） -->
    <div class="hidden md:flex shrink-0 flex-col gap-2">
      {visibleOffers.map((offer) => (
        <AffiliateLink
          href={offer.url}
          provider={offer.provider}
          label={offer.label}
          productName={product.name}
          size="md"
          variant={offer.provider === "rakuten" ? "primary" : "outline"}
        />
      ))}
    </div>
  </div>

  <!-- CTAボタン（モバイル：全幅） -->
  <div class="md:hidden mt-3 flex flex-col gap-2">
    {visibleOffers.map((offer) => (
      <AffiliateLink
        href={offer.url}
        provider={offer.provider}
        label={offer.label}
        productName={product.name}
        size="md"
        variant={offer.provider === "rakuten" ? "primary" : "outline"}
      />
    ))}
  </div>
</div>
