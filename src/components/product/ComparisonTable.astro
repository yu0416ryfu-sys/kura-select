---
import ComparisonTableSort from "./ComparisonTableSort.tsx";
import {
  getVisibleOffers,
  getOfferPriceSummary,
  getEnabledAffiliateProvidersFromEnv,
  getStaticAffiliateProvidersFromEnv,
  type ProductOffer,
} from "../../lib/offers";

const linkProviders = getEnabledAffiliateProvidersFromEnv(import.meta.env);
const priceProviders = getStaticAffiliateProvidersFromEnv(import.meta.env);

interface Product {
  rank: number;
  name: string;
  brand: string;
  price: number;
  capacity: string;
  pricePerUnit?: string;
  rating?: number;
  reviewCount?: number;
  rakutenUrl: string;
  imageUrl?: string;
  offers?: ProductOffer[];
}

interface Props {
  products: Product[];
  caption?: string;
}

const { products, caption = "商品比較表" } = Astro.props;

const yahooSearchFallback = {
  enabled: import.meta.env.PUBLIC_ENABLE_YAHOO_AFFILIATE === "true",
  sid: import.meta.env.VALUECOMMERCE_SID,
  pid: import.meta.env.VALUECOMMERCE_PID,
};
const amazonSearchFallback = {
  enabled: import.meta.env.PUBLIC_ENABLE_AMAZON_AFFILIATE === "true",
  tag: import.meta.env.AMAZON_ASSOCIATE_TAG,
};

const productsForTable = products.map((product) => {
  const rawVisible = getVisibleOffers(product, { enabledProviders: linkProviders, yahooSearchFallback, amazonSearchFallback });
  return {
    ...product,
    // Amazon は price/available/imageUrl を渡さない（SSG 鮮度制約）
    visibleOffers: rawVisible.map((o) => ({
      provider: o.provider,
      label: o.label,
      url: o.url,
      asin: o.asin,
      updatedAt: o.updatedAt instanceof Date ? o.updatedAt.toISOString() : o.updatedAt,
    })),
    priceSummary: getOfferPriceSummary(product, { enabledProviders: priceProviders }),
  };
});
---

<div class="my-8">
  <p class="text-xs text-[var(--color-text-sub)] mb-2">
    ※ 掲載価格は執筆時点のものです。最新価格は各ショップでご確認ください。
  </p>
  <ComparisonTableSort
    products={productsForTable}
    caption={caption}
    enabledProviders={linkProviders}
    client:visible
  />
</div>
