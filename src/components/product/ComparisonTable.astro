---
import ComparisonTableSort from "./ComparisonTableSort.tsx";
import { getVisibleOffers, getOfferPriceSummary, type ProductOffer } from "../../lib/offers";
const ENABLE_YAHOO_AFFILIATE = import.meta.env.PUBLIC_ENABLE_YAHOO_AFFILIATE === "true";

interface Product {
  rank: number;
  name: string;
  brand: string;
  price: number;
  capacity: string;
  pricePerUnit?: string;
  rating?: number;
  reviewCount?: number;
  rakutenUrl: string;
  imageUrl?: string;
  offers?: ProductOffer[];
}

interface Props {
  products: Product[];
  caption?: string;
}

const { products, caption = "商品比較表" } = Astro.props;
const productsForTable = products.map((product) => ({
  ...product,
  visibleOffers: getVisibleOffers(product, { enableYahoo: ENABLE_YAHOO_AFFILIATE }),
  priceSummary: getOfferPriceSummary(product, { enableYahoo: ENABLE_YAHOO_AFFILIATE }),
}));
---

<div class="my-8">
  <p class="text-xs text-[var(--color-text-sub)] mb-2">
    ※ 掲載価格は執筆時点のものです。最新価格は各ショップでご確認ください。
  </p>
  <ComparisonTableSort products={productsForTable} caption={caption} client:visible />
</div>
