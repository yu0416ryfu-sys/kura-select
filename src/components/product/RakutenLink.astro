---
import AffiliateLink from "./AffiliateLink.astro";

interface Props {
  href: string;
  label?: string;
  variant?: "primary" | "outline";
  size?: "sm" | "md" | "lg";
  productName?: string;
}

const {
  href,
  label = "楽天市場で見る",
  variant = "primary",
  size = "md",
  productName,
} = Astro.props;
---

<AffiliateLink
  href={href}
  provider="rakuten"
  label={label}
  variant={variant}
  size={size}
  productName={productName}
/>
