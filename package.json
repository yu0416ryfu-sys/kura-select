{
  "name": "kura-select",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-ogp.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-ogp": "node scripts/generate-ogp.mjs",
    "update-products": "node --experimental-strip-types scripts/update-products.mjs",
    "update-products:dry": "node --experimental-strip-types scripts/update-products.mjs --dry-run",
    "update-yahoo-products": "node --experimental-strip-types scripts/update-yahoo-products.mjs",
    "update-yahoo-products:dry": "node --experimental-strip-types scripts/update-yahoo-products.mjs --dry-run",
    "check-replacements": "node --experimental-strip-types scripts/update-products.mjs --check-replacements",
    "check-additions": "node --experimental-strip-types scripts/update-products.mjs --check-additions",
    "update-amazon-products": "node --experimental-strip-types scripts/update-amazon-products.mjs",
    "update-amazon-products:dry": "node --experimental-strip-types scripts/update-amazon-products.mjs --dry-run",
    "export-ai-rag": "node --experimental-strip-types scripts/export-ai-rag-data.mjs",
    "mcp:kura-content": "node --experimental-strip-types scripts/mcp/kura-content-mcp.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/preact": "^5.0.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^6.1.0",
    "googleapis": "^172.0.0",
    "js-yaml": "^4.1.1",
    "preact": "^10.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "sharp": "^0.34.5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
