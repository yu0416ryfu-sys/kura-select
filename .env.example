# ===================================================
# KuraSelect 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env
# ===================================================

# 楽天アフィリエイトID（楽天アフィリエイト > マイページ > ツールの管理 から取得）
# 形式例: 1234abcd.5678efgh.1234abcd.5678efgh
PUBLIC_RAKUTEN_AFFILIATE_ID=your_affiliate_id_here

# サイトURL（本番デプロイ先）
PUBLIC_SITE_URL=https://www.kura-select.com

# 楽天 Web Service アプリID（商品検索APIに必要）
# 取得: https://webservice.rakuten.co.jp/
RAKUTEN_APPLICATION_ID=your_application_id_here

# 楽天 Web Service アクセスキー（商品検索APIに必要）
RAKUTEN_ACCESS_KEY=your_access_key_here
